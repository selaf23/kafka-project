{
  "name": "bun-kafka-realtime-demo",
  "version": "1.0.0",
  "description": "Real-time Kafka producer/consumer demo with WebSockets",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun --watch run src/server.ts",
    "consumer": "bun run src/consumer.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "kafkajs": "^2.2.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "bun-types": "^1.0.21"
  }
}